{
  "manifest_version": 3,
  "name": "PhishGuard Extension",
  "version": "1.0.3",
  "description": "Scan URLs automatically with your PhishGuard backend directly from your browser.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "downloads",
    "notifications"
  ],
  "host_permissions": ["http://127.0.0.1:8080/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "PhishGuard",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html"
}
